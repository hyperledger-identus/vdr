# Normalize all text files to LF
* text=auto eol=lf

# Scripts -- must be LF (executed in Docker/Linux)
*.sh text eol=lf
*.bash text eol=lf

# Data/config
*.sql text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.properties text eol=lf

# Source code
*.scala text eol=lf
*.kt text eol=lf
*.kts text eol=lf
*.java text eol=lf
*.swift text eol=lf
*.ts text eol=lf
*.js text eol=lf
*.rs text eol=lf
*.go text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf

# Docker
Dockerfile text eol=lf
docker-compose*.yml text eol=lf

# Binary -- never touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.jar binary
*.zip binary
*.tar.gz binary
*.woff binary
*.woff2 binary
*.ttf binary
